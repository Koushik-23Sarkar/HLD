    {
      "id": "XLHPY2AwNK0wGoxGpY35Q",
      "type": "text",
      "x": -21456.593633953446,
      "y": 4608.191924260684,
      "width": 1308.672607421875,
      "height": 630,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 2,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0hzG",
      "roundness": null,
      "seed": 1044959066,
      "version": 589,
      "versionNonce": 1522418251,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1774362644960,
      "link": null,
      "locked": false,
      "text": "Q. how to generate short URL from Long URL ?\n\nhash function:\n    hash(longURL) == ShortURL (unique)\n\n---> Algorithm: (storing)\n        1. user comes with a long URL\n        2. we generate a short URL for the same using hash function\n        3. store the shortURL as key and longURL as value in our hashmap.\n        4. return the shortURL\n---> Algorithm: (redirecting)\n        1. User comes with a short URL.\n        2. We find the eqivanlent long URL by doing map.get(shortURL).\n        3. Redirect the user to longURL (302 redirect)",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Q. how to generate short URL from Long URL ?\n\nhash function:\n    hash(longURL) == ShortURL (unique)\n\n---> Algorithm: (storing)\n        1. user comes with a long URL\n        2. we generate a short URL for the same using hash function\n        3. store the shortURL as key and longURL as value in our hashmap.\n        4. return the shortURL\n---> Algorithm: (redirecting)\n        1. User comes with a short URL.\n        2. We find the eqivanlent long URL by doing map.get(shortURL).\n        3. Redirect the user to longURL (302 redirect)",
      "autoResize": true,
      "lineHeight": 1.25
    },
